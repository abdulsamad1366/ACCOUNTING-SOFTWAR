datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Company {
  id        String   @id @default(uuid())
  name      String
  tagline   String?
  phone     String?
  email     String?
  gstin     String?
  pan       String?
  address   String?
  city      String?
  state     String?
  pincode   String?
  bankName  String?
  accountNo String?
  ifsc      String?
  branch    String?
  upiId     String?
  terms     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  fullName  String
  role      String   @default("ADMIN") // ADMIN, ACCOUNTANT, VIEWER
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Unit {
  id        String    @id @default(uuid())
  name      String    @unique
  symbol    String
  products  Product[]
  createdAt DateTime  @default(now())
}

model Party {
  id          String   @id @default(uuid())
  type        String   // CUSTOMER or SUPPLIER
  name        String
  companyName String?
  phone       String?
  email       String?
  gstin       String?
  address     String?
  city        String?
  state       String?
  creditLimit Float    @default(0)
  balance     Float    @default(0) // Positive = Receive (+), Negative = Pay (-)
  createdDate String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices       Invoice[]
  vouchers       Voucher[]
  ledgerEntries  LedgerEntry[]
}

model Product {
  id             String   @id @default(uuid())
  code           String   @unique
  name           String
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  unitId         String?
  unit           Unit?     @relation(fields: [unitId], references: [id])
  unitName       String   @default("Pcs")
  hsnCode        String
  gstRate        Float    @default(18)
  salePrice      Float    @default(0)
  purchasePrice  Float    @default(0)
  currentStock   Float    @default(0)
  minStockAlert  Float    @default(5)
  barcode        String?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoiceItems   InvoiceItem[]
  stockMovements StockMovement[]
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  type          String   // SALES, PURCHASE, QUOTATION, SALES_RETURN, PURCHASE_RETURN
  partyId       String?
  party         Party?   @relation(fields: [partyId], references: [id])
  partyName     String
  partyPhone    String?
  partyGstin    String?
  date          String
  dueDate       String
  subtotal      Float    @default(0)
  cgstTotal     Float    @default(0)
  sgstTotal     Float    @default(0)
  igstTotal     Float    @default(0)
  discount      Float    @default(0)
  grandTotal    Float    @default(0)
  paidAmount    Float    @default(0)
  status        String   @default("UNPAID") // PAID, UNPAID, PARTIAL, DRAFT, CANCELLED
  notes         String?
  isInterstate  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         InvoiceItem[]
  ledgerEntries LedgerEntry[]
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  productName String
  hsnCode     String
  quantity    Float
  unit        String
  price       Float
  gstRate     Float
  cgstAmount  Float    @default(0)
  sgstAmount  Float    @default(0)
  igstAmount  Float    @default(0)
  total       Float
}

model Voucher {
  id            String   @id @default(uuid())
  voucherNumber String   @unique
  type          String   // PAYMENT_IN, PAYMENT_OUT, CONTRA, EXPENSE
  date          String
  partyId       String?
  party         Party?   @relation(fields: [partyId], references: [id])
  partyName     String?
  category      String   // Rent, Salary, Utility, Payment In, Payment Out
  amount        Float
  paymentMode   String   // CASH, HDFC_BANK, ICICI_BANK, UPI
  referenceNo   String?
  notes         String?
  createdAt     DateTime @default(now())

  ledgerEntries LedgerEntry[]
}

model LedgerEntry {
  id          String   @id @default(uuid())
  voucherId   String?
  voucher     Voucher? @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  partyId     String?
  party       Party?   @relation(fields: [partyId], references: [id], onDelete: SetNull)
  accountName String
  date        String
  debit       Float    @default(0)
  credit      Float    @default(0)
  balance     Float    @default(0)
  narration   String?
  createdAt   DateTime @default(now())
}

model StockMovement {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  type          String   // IN, OUT, ADJUSTMENT
  quantity      Float
  referenceType String   // SALES, PURCHASE, MANUAL
  referenceId   String?
  date          String
  notes         String?
  createdAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  timestamp DateTime @default(now())
}

model Settings {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
